<script is:inline>
  (() => {
    let previewModal;

    const ensureMermaidScript = async () => {
      if (window.mermaid) return window.mermaid;
      if (window.__anthrotechMermaidLoader) return window.__anthrotechMermaidLoader;

      window.__anthrotechMermaidLoader = new Promise((resolve, reject) => {
        const script = document.createElement("script");
        script.src = "https://cdn.docbase.io/mermaid@11.6.0/dist/mermaid.min.js";
        script.async = true;

        script.onload = () => {
          if (!window.mermaid) {
            window.__anthrotechMermaidLoader = undefined;
            reject(new Error("Mermaid failed to load."));
            return;
          }

          window.mermaid.initialize({
            startOnLoad: false,
            securityLevel: "strict",
            theme: "default",
          });

          resolve(window.mermaid);
        };

        script.onerror = () => {
          window.__anthrotechMermaidLoader = undefined;
          reject(new Error("Failed to load Mermaid script."));
        };
        document.head.appendChild(script);
      });

      return window.__anthrotechMermaidLoader;
    };

    const upgradeCodeBlocks = () => {
      const blocks = document.querySelectorAll(
        'pre[data-language="mermaid"], pre > code.language-mermaid'
      );

      for (const block of blocks) {
        const pre =
          block instanceof HTMLPreElement
            ? block
            : block.parentElement instanceof HTMLPreElement
              ? block.parentElement
              : null;

        if (!(pre instanceof HTMLElement) || pre.dataset.mermaidUpgraded === "1") continue;

        const chart = pre.textContent?.trimEnd();
        if (!chart) continue;

        const container = document.createElement("div");
        container.className = "mermaid";
        container.textContent = chart;

        pre.dataset.mermaidUpgraded = "1";
        pre.replaceWith(container);
      }
    };

    const ensurePreviewModal = () => {
      if (previewModal) return previewModal;

      const root = document.createElement("div");
      root.className = "mermaid-preview";
      root.hidden = true;
      root.innerHTML = `
        <div class="mermaid-preview__backdrop" data-close="1"></div>
        <div class="mermaid-preview__dialog" role="dialog" aria-modal="true" aria-label="Mermaid preview">
          <div class="mermaid-preview__toolbar">
            <button type="button" data-action="zoom-out" aria-label="Zoom out">-</button>
            <button type="button" data-action="zoom-in" aria-label="Zoom in">+</button>
            <button type="button" data-action="actual-size">実寸</button>
            <button type="button" data-action="reset">全体表示</button>
            <button type="button" data-close="1" aria-label="Close preview">Close</button>
          </div>
          <div class="mermaid-preview__viewport">
            <div class="mermaid-preview__canvas"></div>
          </div>
        </div>
      `;

      const viewport = root.querySelector(".mermaid-preview__viewport");
      const canvas = root.querySelector(".mermaid-preview__canvas");
      let scale = 1;
      let offsetX = 0;
      let offsetY = 0;
      let dragState = null;
      let pinchState = null;
      let baseWidth = 0;
      let baseHeight = 0;
      let previewSvg = null;

      const syncSvgSize = () => {
        if (!(previewSvg instanceof SVGElement)) return;
        if (!baseWidth || !baseHeight) return;

        const width = baseWidth * scale;
        const height = baseHeight * scale;

        previewSvg.setAttribute("width", String(width));
        previewSvg.setAttribute("height", String(height));
        previewSvg.style.width = `${width}px`;
        previewSvg.style.height = `${height}px`;
        previewSvg.style.maxWidth = "none";
      };

      const applyTransform = () => {
        if (!(canvas instanceof HTMLElement)) return;
        canvas.style.transform = `translate(${offsetX}px, ${offsetY}px)`;
        syncSvgSize();
      };

      const getViewportMetrics = () => {
        if (!(viewport instanceof HTMLElement)) {
          return {
            innerWidth: 0,
            innerHeight: 0,
            paddingLeft: 0,
            paddingTop: 0,
          };
        }

        const styles = window.getComputedStyle(viewport);
        const paddingLeft = Number.parseFloat(styles.paddingLeft) || 0;
        const paddingRight = Number.parseFloat(styles.paddingRight) || 0;
        const paddingTop = Number.parseFloat(styles.paddingTop) || 0;
        const paddingBottom = Number.parseFloat(styles.paddingBottom) || 0;

        return {
          innerWidth: Math.max(viewport.clientWidth - paddingLeft - paddingRight, 0),
          innerHeight: Math.max(viewport.clientHeight - paddingTop - paddingBottom, 0),
          paddingLeft,
          paddingTop,
        };
      };

      const centerView = () => {
        if (!(viewport instanceof HTMLElement)) return;
        if (!baseWidth || !baseHeight) return;

        const { innerWidth, innerHeight } = getViewportMetrics();
        const scaledWidth = baseWidth * scale;
        const scaledHeight = baseHeight * scale;

        offsetX = scaledWidth <= innerWidth
          ? (innerWidth - scaledWidth) / 2
          : 0;
        offsetY = scaledHeight <= innerHeight
          ? (innerHeight - scaledHeight) / 2
          : 0;
        applyTransform();
      };

      const getFitScale = () => {
        if (!(viewport instanceof HTMLElement)) return 1;
        if (!baseWidth || !baseHeight) return 1;

        const { innerWidth, innerHeight } = getViewportMetrics();
        const availableWidth = Math.max(innerWidth, 1);
        const availableHeight = Math.max(innerHeight, 1);
        return Math.min(1, availableWidth / baseWidth, availableHeight / baseHeight);
      };

      const closePreview = () => {
        root.hidden = true;
        document.body.classList.remove("mermaid-preview-open");
        scale = 1;
        offsetX = 0;
        offsetY = 0;
        dragState = null;
        pinchState = null;
        if (canvas instanceof HTMLElement) {
          canvas.style.transform = "translate(0px, 0px)";
          canvas.replaceChildren();
        }
        previewSvg = null;
        baseWidth = 0;
        baseHeight = 0;
      };

      const applyScale = (nextScale, originX = 0, originY = 0) => {
        const clampedScale = Math.min(3, Math.max(0.5, nextScale));
        const ratio = clampedScale / scale;
        offsetX = originX - (originX - offsetX) * ratio;
        offsetY = originY - (originY - offsetY) * ratio;
        scale = clampedScale;
        applyTransform();
      };

      const applyScaleCentered = (nextScale) => {
        scale = Math.min(3, Math.max(0.5, nextScale));
        centerView();
      };

      const getViewportPoint = (clientX, clientY) => {
        if (!(viewport instanceof HTMLElement)) {
          return { x: 0, y: 0 };
        }

        const rect = viewport.getBoundingClientRect();
        const { paddingLeft, paddingTop } = getViewportMetrics();
        return {
          x: clientX - rect.left - paddingLeft,
          y: clientY - rect.top - paddingTop,
        };
      };

      const resetView = () => {
        scale = getFitScale();
        dragState = null;
        pinchState = null;
        centerView();
      };

      const showActualSize = () => {
        scale = 1;
        dragState = null;
        pinchState = null;
        centerView();
      };

      const touchDistance = (touches) => {
        if (touches.length < 2) return 0;
        const dx = touches[0].clientX - touches[1].clientX;
        const dy = touches[0].clientY - touches[1].clientY;
        return Math.hypot(dx, dy);
      };

      const touchCenter = (touches) => ({
        x: (touches[0].clientX + touches[1].clientX) / 2,
        y: (touches[0].clientY + touches[1].clientY) / 2,
      });

      root.addEventListener("click", (event) => {
        const target = event.target;
        if (!(target instanceof HTMLElement)) return;

        if (target.dataset.close === "1") {
          closePreview();
          return;
        }

        if (target.dataset.action === "zoom-in") {
          applyScaleCentered(scale + 0.2);
        }
        if (target.dataset.action === "zoom-out") {
          applyScaleCentered(scale - 0.2);
        }
        if (target.dataset.action === "actual-size") showActualSize();
        if (target.dataset.action === "reset") resetView();
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && !root.hidden) {
          closePreview();
        }
      });

      if (viewport instanceof HTMLElement) {
        viewport.addEventListener("pointerdown", (event) => {
          if (root.hidden || event.pointerType === "touch" || event.button !== 0) return;

          dragState = {
            startX: event.clientX,
            startY: event.clientY,
            originX: offsetX,
            originY: offsetY,
          };
          viewport.setPointerCapture(event.pointerId);
        });

        viewport.addEventListener("pointermove", (event) => {
          if (root.hidden || event.pointerType === "touch" || !dragState) return;

          offsetX = dragState.originX + (event.clientX - dragState.startX);
          offsetY = dragState.originY + (event.clientY - dragState.startY);
          applyTransform();
        });

        viewport.addEventListener("pointerup", () => {
          dragState = null;
        });

        viewport.addEventListener("pointercancel", () => {
          dragState = null;
        });

        viewport.addEventListener("lostpointercapture", () => {
          dragState = null;
        });

        viewport.addEventListener("pointerleave", () => {
          dragState = null;
        });

        viewport.addEventListener(
          "wheel",
          (event) => {
            if (root.hidden) return;
            event.preventDefault();
            const point = getViewportPoint(event.clientX, event.clientY);
            applyScale(scale + (event.deltaY < 0 ? 0.12 : -0.12), point.x, point.y);
          },
          { passive: false }
        );

        viewport.addEventListener(
          "touchstart",
          (event) => {
            if (root.hidden) return;

            if (event.touches.length === 1) {
              const touch = event.touches[0];
              dragState = {
                startX: touch.clientX,
                startY: touch.clientY,
                originX: offsetX,
                originY: offsetY,
              };
              pinchState = null;
            }

            if (event.touches.length === 2) {
              const center = touchCenter(event.touches);
              const point = getViewportPoint(center.x, center.y);
              pinchState = {
                startDistance: touchDistance(event.touches),
                startScale: scale,
                centerX: point.x,
                centerY: point.y,
              };
              dragState = null;
              event.preventDefault();
            }
          },
          { passive: false }
        );

        viewport.addEventListener(
          "touchmove",
          (event) => {
            if (root.hidden) return;

            if (event.touches.length === 1 && dragState) {
              const touch = event.touches[0];
              offsetX = dragState.originX + (touch.clientX - dragState.startX);
              offsetY = dragState.originY + (touch.clientY - dragState.startY);
              applyTransform();
              event.preventDefault();
            }

            if (event.touches.length === 2 && pinchState) {
              const distance = touchDistance(event.touches);
              const ratio = distance / pinchState.startDistance;
              const center = touchCenter(event.touches);
              const point = getViewportPoint(center.x, center.y);
              applyScale(
                pinchState.startScale * ratio,
                point.x || pinchState.centerX,
                point.y || pinchState.centerY
              );
              event.preventDefault();
            }
          },
          { passive: false }
        );

        viewport.addEventListener("touchend", () => {
          if (root.hidden) return;
          dragState = null;
          pinchState = null;
        });

        viewport.addEventListener("touchcancel", () => {
          dragState = null;
          pinchState = null;
        });

        viewport.addEventListener(
          "gesturestart",
          (event) => {
            if (!root.hidden) event.preventDefault();
          },
          { passive: false }
        );

        viewport.addEventListener(
          "gesturechange",
          (event) => {
            if (!root.hidden) event.preventDefault();
          },
          { passive: false }
        );
      }

      document.body.appendChild(root);

      previewModal = {
        open(source) {
          if (!(canvas instanceof HTMLElement)) return;
          canvas.replaceChildren(source.cloneNode(true));
          previewSvg = canvas.querySelector("svg");
          if (previewSvg instanceof SVGElement) {
            const viewBox = previewSvg.viewBox?.baseVal;
            const rect = previewSvg.getBoundingClientRect();
            baseWidth = viewBox && viewBox.width ? viewBox.width : rect.width;
            baseHeight = viewBox && viewBox.height ? viewBox.height : rect.height;
            if (!baseWidth || !baseHeight) {
              baseWidth = rect.width || 1;
              baseHeight = rect.height || 1;
            }
            previewSvg.style.maxWidth = "none";
          }
          root.hidden = false;
          document.body.classList.add("mermaid-preview-open");
          requestAnimationFrame(() => {
            resetView();
          });
        },
      };

      return previewModal;
    };

    const setupPreviewTriggers = () => {
      const nodes = document.querySelectorAll(".mermaid");

      for (const node of nodes) {
        if (!(node instanceof HTMLElement) || node.dataset.mermaidPreviewBound === "1") continue;

        node.tabIndex = 0;
        node.setAttribute("role", "button");
        node.setAttribute("aria-label", "Open Mermaid preview");

        const openPreview = () => {
          const svg = node.querySelector("svg");
          if (!(svg instanceof SVGElement)) return;
          ensurePreviewModal().open(svg);
        };

        node.addEventListener("click", openPreview);
        node.addEventListener("keydown", (event) => {
          if (event.key === "Enter" || event.key === " ") {
            event.preventDefault();
            openPreview();
          }
        });

        node.dataset.mermaidPreviewBound = "1";
      }
    };

    const renderMermaid = async () => {
      upgradeCodeBlocks();

      const nodes = Array.from(document.querySelectorAll(".mermaid")).filter((node) => {
        return node instanceof HTMLElement && node.dataset.mermaidRendered !== "1";
      });

      if (nodes.length === 0) return;

      const mermaid = await ensureMermaidScript();
      await mermaid.run({ nodes });

      for (const node of nodes) {
        if (!(node instanceof HTMLElement)) continue;
        node.dataset.mermaidRendered = "1";
      }

      setupPreviewTriggers();
    };

    const start = () => {
      renderMermaid().catch((error) => {
        console.error("[Mermaid] render failed", error);
      });
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", start, { once: true });
      return;
    }

    start();
  })();
</script>

<style is:global>
  .mermaid {
    margin: 1rem 0;
    overflow-x: auto;
    cursor: zoom-in;
  }

  .mermaid svg {
    display: block;
    height: auto;
  }

  .mermaid-preview-open {
    overflow: hidden;
  }

  .mermaid-preview {
    position: fixed;
    inset: 0;
    z-index: 1000;
  }

  .mermaid-preview__backdrop {
    position: absolute;
    inset: 0;
    background: rgb(15 23 42 / 0.82);
  }

  .mermaid-preview__dialog {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    width: min(96vw, 1400px);
    height: min(92vh, 920px);
    margin: 4vh auto;
    background: #fff;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 24px 60px rgb(15 23 42 / 0.35);
  }

  .mermaid-preview__toolbar {
    display: flex;
    gap: 0.5rem;
    justify-content: flex-end;
    padding: 0.75rem;
    border-bottom: 1px solid #e5e7eb;
    background: #f8fafc;
  }

  .mermaid-preview__toolbar button {
    border: 1px solid #cbd5e1;
    background: #fff;
    color: #0f172a;
    border-radius: 999px;
    padding: 0.45rem 0.85rem;
    font: inherit;
    cursor: pointer;
  }

  .mermaid-preview__viewport {
    flex: 1;
    overflow: auto;
    padding: 1rem;
    touch-action: none;
    overscroll-behavior: contain;
    cursor: grab;
    background:
      radial-gradient(circle at 1px 1px, rgb(148 163 184 / 0.25) 1px, transparent 0);
    background-size: 18px 18px;
  }

  .mermaid-preview__viewport:active {
    cursor: grabbing;
  }

  .mermaid-preview__canvas {
    width: max-content;
    transform-origin: top left;
    will-change: transform;
  }

  .mermaid-preview__canvas svg {
    display: block;
    height: auto;
    max-width: none;
  }

  @media (max-width: 640px) {
    .mermaid-preview__dialog {
      width: 100vw;
      height: 100vh;
      margin: 0;
      border-radius: 0;
    }
  }
</style>
