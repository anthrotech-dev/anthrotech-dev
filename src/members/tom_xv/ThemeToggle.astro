---
---

<button id="tom-theme-toggle" aria-label="ダーク/ライト切替" title="テーマ切替">
  🌙
</button>

<div id="tom-theme-overlay" aria-hidden="true">
  <span id="tom-theme-overlay-icon">🌙</span>
  <span id="tom-theme-overlay-label">切り替え中…</span>
</div>

<style>
  #tom-theme-toggle {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    width: 2.8rem;
    height: 2.8rem;
    border-radius: 50%;
    border: 1px solid #c4b5fd;
    background: linear-gradient(135deg, #f5f3ff, #ede9fe);
    cursor: pointer;
    font-size: 1.2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 10px rgba(109, 77, 193, 0.2);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    z-index: 600;
  }

  #tom-theme-toggle:hover {
    transform: scale(1.12) rotate(15deg);
    box-shadow: 0 4px 16px rgba(109, 77, 193, 0.35);
  }

  /* ===== THEME SWITCH OVERLAY ===== */

  #tom-theme-overlay {
    position: fixed;
    inset: 0;
    z-index: 500;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.32s cubic-bezier(0.4, 0, 0.2, 1);
    background: #f5f3ff;
  }

  #tom-theme-overlay.visible {
    opacity: 1;
    pointer-events: all;
  }

  #tom-theme-overlay.to-dark {
    background: radial-gradient(ellipse at center, #1a1a30 0%, #0d0d1a 70%);
  }

  #tom-theme-overlay.to-light {
    background: radial-gradient(ellipse at center, #ede9fe 0%, #f5f3ff 70%);
  }

  #tom-theme-overlay-icon {
    font-size: 2.8rem;
    display: block;
    animation: tom-overlay-spin 0.75s cubic-bezier(0.4, 0, 0.2, 1) infinite;
  }

  #tom-theme-overlay-label {
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0.1em;
  }

  #tom-theme-overlay.to-dark #tom-theme-overlay-label {
    color: #c4b5fd;
  }

  #tom-theme-overlay.to-light #tom-theme-overlay-label {
    color: #5c4a9e;
  }

  @keyframes tom-overlay-spin {
    0%   { transform: rotate(0deg)   scale(1);   }
    50%  { transform: rotate(180deg) scale(1.3); }
    100% { transform: rotate(360deg) scale(1);   }
  }

  /* ===== DARK MODE OVERRIDES ===== */

  :global(html.dark-tom) {
    background-color: #0d0d1a !important;
    color: #d4d4e8 !important;
  }

  :global(html.dark-tom body),
  :global(html.dark-tom #main),
  :global(html.dark-tom #sidebar),
  :global(html.dark-tom #wrap) {
    background-color: #0d0d1a;
    color: #d4d4e8;
  }

  :global(html.dark-tom article) {
    background-color: #13132a;
    border-color: #2a2a45;
  }

  :global(html.dark-tom article *),
  :global(html.dark-tom article p),
  :global(html.dark-tom article li) {
    color: #d4d4e8;
  }

  :global(html.dark-tom article a) {
    color: #818cf8 !important;
  }

  :global(html.dark-tom pre),
  :global(html.dark-tom pre *) {
    background-color: #1a1a30 !important;
    color: #e2e0ff !important;
  }

  :global(html.dark-tom h1),
  :global(html.dark-tom h2),
  :global(html.dark-tom h3),
  :global(html.dark-tom h4) {
    color: #e2e0ff;
  }

  /* テーブル（ダークモード） */
  :global(html.dark-tom article th),
  :global(html.dark-tom article td) {
    border: 1px solid #2a2a45;
    background: #13132a;
    color: #d4d4e8;
  }

  :global(html.dark-tom article th) {
    background: #1a1a30;
    color: #e2e0ff;
  }

  /* サイドバー */
  :global(html.dark-tom #title) {
    color: #e2e0ff !important;
  }

  :global(html.dark-tom #sidebar a) {
    color: #a78bfa !important;
  }

  /* ProfileLinks */
  :global(html.dark-tom .link-card) {
    background: linear-gradient(135deg, #1e1b3a, #231b50) !important;
    border-color: #3d2d8a !important;
  }

  :global(html.dark-tom .link-card:hover) {
    background: linear-gradient(135deg, #2d1f6e, #3d2d8a) !important;
    box-shadow: 0 4px 16px rgba(124, 99, 219, 0.35) !important;
  }

  :global(html.dark-tom .link-name) {
    color: #c4b5fd !important;
  }

  :global(html.dark-tom .link-url) {
    color: #7c6fad !important;
  }

  :global(html.dark-tom .link-arrow) {
    color: #5c4a9e !important;
  }

  :global(html.dark-tom .section-title) {
    color: #a78bfa !important;
    border-bottom-color: #4c3d8a !important;
  }

  /* TranslateBot portfolio */
  :global(html.dark-tom .tb-feature) {
    background: #1a1a30 !important;
    border-color: #2d2d50 !important;
  }

  :global(html.dark-tom .tb-feature-title) {
    color: #c4b5fd !important;
  }

  :global(html.dark-tom .tb-feature-desc) {
    color: #9090b0 !important;
  }

  :global(html.dark-tom .tb-section-title) {
    color: #a78bfa !important;
    border-bottom-color: #4c3d8a !important;
  }

  :global(html.dark-tom .tb-subtitle) {
    color: #9090b0 !important;
  }

  :global(html.dark-tom .tb-badge.ts)      { background: #1e3a5f !important; color: #93c5fd !important; border-color: #2d4f7f !important; }
  :global(html.dark-tom .tb-badge.bun)     { background: #2d1f0a !important; color: #fbbf24 !important; border-color: #4d3010 !important; }
  :global(html.dark-tom .tb-badge.deepl)   { background: #0a1f3f !important; color: #60a5fa !important; border-color: #0f3060 !important; }
  :global(html.dark-tom .tb-badge.redis)   { background: #3f0a0a !important; color: #fca5a5 !important; border-color: #601010 !important; }
  :global(html.dark-tom .tb-badge.discord) { background: #1a1b4b !important; color: #a5b4fc !important; border-color: #2a2b6b !important; }
  :global(html.dark-tom .tb-badge.raspi)   { background: #3f0a1e !important; color: #f9a8c9 !important; border-color: #7a1535 !important; }
  :global(html.dark-tom .tb-badge.meteo)   { background: #0a2030 !important; color: #7dd3fc !important; border-color: #0e3a55 !important; }
  :global(html.dark-tom .tb-badge.jma)     { background: #0a2010 !important; color: #86efac !important; border-color: #14532d !important; }
  :global(html.dark-tom .tb-badge.react)   { background: #0e3a55 !important; color: #7dd3fc !important; border-color: #0e3a55 !important; }
  :global(html.dark-tom .tb-badge.pwa)     { background: #1a1b4b !important; color: #a5b4fc !important; border-color: #2a2b6b !important; }
  :global(html.dark-tom .tb-badge.ytdlp)   { background: #3f0a0a !important; color: #fca5a5 !important; border-color: #601010 !important; }
  :global(html.dark-tom .tb-badge.http)    { background: #0a2010 !important; color: #86efac !important; border-color: #14532d !important; }
  :global(html.dark-tom .tb-badge.npm)     { background: #3f0a0a !important; color: #fca5a5 !important; border-color: #601010 !important; }

  :global(html.dark-tom .tb-link-btn) {
    background: linear-gradient(135deg, #1e1b3a, #231b50) !important;
    border-color: #3d2d8a !important;
    color: #c4b5fd !important;
  }

  :global(html.dark-tom .tb-link-btn:hover) {
    background: linear-gradient(135deg, #2d1f6e, #3d2d8a) !important;
  }

  /* Raspi Weather Station badges */
  :global(html.dark-tom .tb-badge.raspi)  { background: #3f0a1e !important; color: #f9a8c9 !important; border-color: #7a1535 !important; }
  :global(html.dark-tom .tb-badge.meteo)  { background: #0a2030 !important; color: #7dd3fc !important; border-color: #0e3a55 !important; }
  :global(html.dark-tom .tb-badge.jma)    { background: #0a2010 !important; color: #86efac !important; border-color: #14532d !important; }

  /* トグルボタン自体のダーク状態 */
  :global(html.dark-tom) #tom-theme-toggle {
    background: linear-gradient(135deg, #1e1b3a, #2d1f6e);
    border-color: #4c3d8a;
    box-shadow: 0 2px 10px rgba(138, 110, 230, 0.3);
  }
</style>

<script>
  const btn = document.getElementById('tom-theme-toggle');
  if (btn) {
    const html = document.documentElement;
    const DARK_CLASS = 'dark-tom';
    const STORAGE_KEY = 'tom-theme';
    let switching = false;

    const apply = (dark: boolean) => {
      html.classList.toggle(DARK_CLASS, dark);
      btn.textContent = dark ? '☀️' : '🌙';
    };

    // デフォルトはダーク。明示的に 'light' が保存されている場合のみライトテーマ
    apply(localStorage.getItem(STORAGE_KEY) !== 'light');

    btn.addEventListener('click', () => {
      if (switching) return;
      switching = true;

      const isDark = html.classList.contains(DARK_CLASS);
      const overlay = document.getElementById('tom-theme-overlay') as HTMLElement | null;
      const overlayIcon = document.getElementById('tom-theme-overlay-icon');

      if (!overlay || !overlayIcon) {
        apply(!isDark);
        localStorage.setItem(STORAGE_KEY, isDark ? 'light' : 'dark');
        switching = false;
        return;
      }

      // オーバーレイを切り替え先テーマに合わせて準備
      overlay.className = isDark ? 'to-light' : 'to-dark';
      overlayIcon.textContent = isDark ? '☀️' : '🌙';

      // フェードイン
      overlay.classList.add('visible');

      // オーバーレイが完全に表示されたらテーマを切り替え
      setTimeout(() => {
        localStorage.setItem(STORAGE_KEY, isDark ? 'light' : 'dark');
        apply(!isDark);

        // 少し間を置いてフェードアウト
        setTimeout(() => {
          overlay.classList.remove('visible');
          setTimeout(() => { switching = false; }, 350);
        }, 120);
      }, 320);
    });
  }
</script>
