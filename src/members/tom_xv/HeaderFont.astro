<script>
  let style = document.getElementById('tb-name-gradient-style');
  if (!(style instanceof HTMLStyleElement)) {
    style = document.createElement('style');
    style.id = 'tb-name-gradient-style';
    document.head.appendChild(style);
  }

  if (style instanceof HTMLStyleElement) {
    style.textContent = `
      @font-face {
        font-family: 'Zpix';
        src: url('https://raw.githubusercontent.com/SolidZORO/zpix-pixel-font/master/website/zpix.woff2') format('woff2');
        font-display: swap;
      }

      @keyframes tb-name-gradient {
        0% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
        100% { background-position: 0% 50%; }
      }


      .member-header {
        display: flex;
        align-items: center;
        gap: 1rem;
        width: fit-content;
        max-width: 100%;
        margin-right: 0;
        padding: 1rem 1.25rem;
        border: 1px solid #ccc;
        border-radius: 20px;
        background: #fff;
        box-shadow: 0 8px 18px -12px rgba(0, 0, 0, 0.18);
        box-sizing: border-box;
      }

      html.dark-tom .member-header {
        border-color: #3a3448;
        background: #1f1b2e;
        box-shadow: 0 12px 24px -16px rgba(0, 0, 0, 0.42);
      }

      .member-header .avatar {
        border: 2px solid #e9d5ff;
        box-shadow: 0 0 0 4px rgba(255, 255, 255, 0.72);
      }

      html.dark-tom .member-header .avatar {
        border-color: rgba(196, 181, 253, 0.35);
        box-shadow: 0 0 0 4px rgba(24, 16, 32, 0.82);
      }

      .tb-title-root {
        font-family: 'Zpix', sans-serif;
        letter-spacing: 0.04em;
        white-space: normal;
        line-height: 1.25;
        margin: 0;
        filter: drop-shadow(0 1px 2px rgba(124, 58, 237, 0.12));
      }

      html.dark-tom .tb-title-root {
        filter: drop-shadow(0 1px 3px rgba(0, 0, 0, 0.28));
      }

      .tb-title-gradient {
        background: linear-gradient(135deg, #ef4444, #ec4899, #c026d3, #a855f7, #f43f5e);
        background-size: 220% 220%;
        animation: tb-name-gradient 6s ease infinite;
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent !important;
        -webkit-text-fill-color: transparent;
      }

      .tb-title-line {
        display: inline;
      }

      .tb-title-smooth {
        clip-path: inset(0 100% 0 0);
        display: inline-block;
        line-height: 1;
        transition: 1.4s cubic-bezier(0.37, 0, 0.63, 1);
        transition-property: clip-path;
      }

      .tb-title-root.is-animated .tb-title-smooth {
        clip-path: inset(0);
      }

      .tb-title-swap {
        position: relative;
        display: inline-grid;
        vertical-align: baseline;
        margin-left: 0.18em;
      }

      .tb-title-swap > span {
        grid-area: 1 / 1;
        transition: opacity 0.55s ease, transform 0.55s ease;
        will-change: opacity, transform;
      }

      .tb-title-primary {
        opacity: 1;
        transform: translateY(0);
      }

      .tb-title-alt {
        opacity: 0;
        transform: translateY(0.55em);
      }

      .tb-title-swap.is-alt .tb-title-primary {
        opacity: 0;
        transform: translateY(-0.55em);
      }

      .tb-title-swap.is-alt .tb-title-alt {
        opacity: 1;
        transform: translateY(0);
      }

      @media (max-width: 900px) {
        .member-header {
          width: 100%;
          margin-right: 0;
        }
      }

      @media (max-width: 700px) {
        .member-header {
          padding: 0.9rem 1rem;
          gap: 0.85rem;
          border-radius: 18px;
        }

        .tb-title-root {
          font-size: calc(2em - 8px);
        }

        .tb-title-line {
          display: block;
        }

        .tb-title-swap {
          display: grid;
          margin-left: 0;
          margin-top: 0.08em;
        }
      }
    `;
  }

  const title = document.querySelector('.member-header h1');
  if (title instanceof HTMLElement) {
    title.classList.add('tb-title-root');
    title.innerHTML = `
      <span class="tb-title-smooth">
        <span class="tb-title-line tb-title-gradient">トム |</span>
        <span class="tb-title-swap" aria-label="Lóng Zǐxūn Tron または 龙 紫熏トロン">
          <span class="tb-title-primary tb-title-gradient">Lóng Zǐxūn Tron</span>
          <span class="tb-title-alt tb-title-gradient">龙 紫熏トロン</span>
        </span>
      </span>
    `;

    requestAnimationFrame(() => {
      title.classList.add('is-animated');
    });

    const swap = title.querySelector('.tb-title-swap');
    if (swap instanceof HTMLElement) {
      let alt = false;
      setInterval(() => {
        alt = !alt;
        swap.classList.toggle('is-alt', alt);
      }, 3800);
    }
  }
</script>
