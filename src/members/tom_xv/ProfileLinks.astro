---
const links = [
  {
    name: '自己紹介カード',
    url: 'https://lit.link/TomXV',
    display: 'lit.link/TomXV',
    favicon: 'https://www.google.com/s2/favicons?domain=https://lit.link&sz=64',
  },
  {
    name: 'ウェブサイト',
    url: 'https://mypage.x2rn.net',
    display: 'mypage.x2rn.net',
    emoji: '🌐',
  },
  {
    name: 'Twitter / X',
    url: 'https://twitter.x2rn.net',
    display: 'twitter.x2rn.net',
    favicon: 'https://www.google.com/s2/favicons?domain=https://x.com&sz=64',
  },
  {
    name: 'GitHub',
    url: 'https://github.x2rn.net',
    display: 'github.x2rn.net',
    favicon: 'https://www.google.com/s2/favicons?domain=https://github.com&sz=64',
  },
  {
    name: 'コンカレ',
    url: 'https://concrnt.world/lugiaxetomxv.net',
    display: 'concrnt.world',
    favicon: 'https://www.google.com/s2/favicons?domain=https://concrnt.world&sz=64',
  },
];
---

<section class="links-section">
  <h2 class="section-title">各種リンク</h2>
  <div class="links-grid">
    {links.map((link) => (
      <a href={link.url} class="link-card" target="_blank" rel="noopener noreferrer">
        <span class="link-icon">
          {link.favicon ? (
            <img src={link.favicon} alt="" class="link-favicon" loading="lazy" />
          ) : (
            <span class="link-emoji" aria-hidden="true">{link.emoji}</span>
          )}
        </span>
        <div class="link-body">
          <span class="link-name">{link.name}</span>
          <span class="link-url">{link.display}</span>
        </div>
        <span class="link-arrow">→</span>
      </a>
    ))}
  </div>
</section>

<style>
  .links-section {
    margin: 0;
  }

  .section-title {
    font-size: 1rem;
    font-weight: bold;
    color: #5c4a9e;
    margin: 0 0 0.9rem !important;
    padding-bottom: 0.4rem;
    border-bottom: 2px solid #c4b5fd;
    letter-spacing: 0.03em;
  }

  .links-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .link-card {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    padding: 0.75rem 1rem;
    border-radius: 12px;
    background: linear-gradient(135deg, #f5f3ff, #ede9fe);
    border: 1px solid #c4b5fd;
    text-decoration: none !important;
    color: #2d1f6e !important;
    flex: 1 1 220px;
    min-width: 220px;
    box-sizing: border-box;
    transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
  }

  .link-card:hover {
    background: linear-gradient(135deg, #ede9fe, #ddd6fe);
    transform: translateX(6px);
    box-shadow: 0 4px 16px rgba(109, 77, 193, 0.18);
  }

  .link-icon {
    width: 2rem;
    height: 2rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    line-height: 1;
  }

  .link-favicon {
    width: 1.35rem;
    height: 1.35rem;
    display: block;
    border-radius: 6px;
    object-fit: contain;
  }

  .link-emoji {
    font-size: 1.2rem;
    line-height: 1;
    display: block;
  }

  .link-body {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    flex: 1;
    min-width: 0;
  }

  .link-name {
    font-size: 0.9rem;
    font-weight: 600;
    color: #3d2d8a;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .link-url {
    font-size: 0.75rem;
    color: #7c6fad;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .link-arrow {
    font-size: 1rem;
    color: #a79fd4;
    flex-shrink: 0;
    transition: transform 0.15s ease;
  }

  .link-card:hover .link-arrow {
    transform: translateX(3px);
  }

  @media (max-width: 700px) {
    .links-grid {
      gap: 0.5rem;
    }

    .link-card {
      flex: 1 1 100%;
      min-width: 100%;
      max-width: 100%;
      gap: 0.7rem;
      padding: 0.72rem 0.8rem;
    }

    .link-arrow {
      margin-left: auto;
    }
  }
</style>
